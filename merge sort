    int size ,n, i;
    printf("enter size of array ");
    scanf("%d",& size);
    int arr[size];
    printf("enter array value: ");
    for ( int i=0;i<size; i++)
        scanf(" %d,&arr[i]");
        printf(" sort using merge");
    for(int i=1 ; i<n ; i++);
    int key= arr[i];
